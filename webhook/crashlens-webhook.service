[Unit]
Description=CrashLens Webhook Server
After=docker.service
Wants=docker.service

[Service]
Type=simple
WorkingDirectory=/root/crashlens-webhook
EnvironmentFile=/root/crashlens-webhook/.env
ExecStart=/usr/bin/python3 -m gunicorn -w 1 -b 127.0.0.1:8765 --timeout 120 webhook:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
